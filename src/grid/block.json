{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "house-products/grid",
    "version": "1.1.0",
    "title": "House Products Grid",
    "category": "widgets",
    "icon": "grid-view",
    "description": "Display WooCommerce products in a modern grid layout with Secure Custom Fields house specifications.",
    "keywords": [
        "products",
        "grid",
        "woocommerce",
        "house",
        "real estate"
    ],
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ],
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "textdomain": "house-products-carousel",
    "attributes": {
        "productsCount": {
            "type": "number",
            "default": 8
        },
        "columns": {
            "type": "number",
            "default": 3
        },
        "category": {
            "type": "number",
            "default": 0
        },
        "excludeCategories": {
            "type": "array",
            "default": []
        },
        "showRating": {
            "type": "boolean",
            "default": true
        },
        "orderBy": {
            "type": "string",
            "default": "date"
        },
        "enableAnimation": {
            "type": "boolean",
            "default": true
        },
        "animationDuration": {
            "type": "number",
            "default": 800
        },
        "animationStagger": {
            "type": "number",
            "default": 150
        }
    },
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "render": "file:./render.php"
}
