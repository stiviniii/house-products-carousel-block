{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "house-products/categories-carousel",
    "version": "1.1.0",
    "title": "House Categories Carousel",
    "category": "widgets",
    "icon": "category",
    "description": "Display WooCommerce product categories in a modern carousel.",
    "keywords": [
        "categories",
        "carousel",
        "woocommerce",
        "house",
        "real estate"
    ],
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ],
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "textdomain": "house-products-carousel",
    "attributes": {
        "categoryIds": {
            "type": "array",
            "default": []
        },
        "columns": {
            "type": "number",
            "default": 3
        },
        "showProductCount": {
            "type": "boolean",
            "default": true
        },
        "autoplay": {
            "type": "boolean",
            "default": false
        },
        "showArrows": {
            "type": "boolean",
            "default": true
        },
        "enableAnimation": {
            "type": "boolean",
            "default": true
        },
        "animationDuration": {
            "type": "number",
            "default": 800
        },
        "animationStagger": {
            "type": "number",
            "default": 150
        },
        "trackOverflowVisible": {
            "type": "boolean",
            "default": false
        }
    },
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "render": "file:./render.php"
}
